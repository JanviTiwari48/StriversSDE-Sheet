TC:O(n)
SC:O(n)

class Solution {
    public int longestSubarray(int[] arr, int k) {
      
      
     HashMap<Integer,Integer>map=new HashMap<>();
     int psum=0;
     int maxL=0;
     
     for(int i=0;i<arr.length;i++){
         psum=psum+arr[i];
         
         if(psum==k)maxL=i+1;
         
     
     int rem=psum-k;
     
     if(map.containsKey(rem))maxL=Math.max(maxL,i-map.get(rem));
        
        if(!map.containsKey(psum))map.put(psum,i);
     }
     return maxL;
    }
    
}
