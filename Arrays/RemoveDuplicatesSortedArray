class Solution {
    ArrayList<Integer> removeDuplicates(int[] arr) {
        
         ArrayList<Integer>ans=new ArrayList<>();
        
        int i=0;
        ans.add(arr[i]);
        
        for(int j=1;j<arr.length;j++){
            if(arr[i]!=arr[j]){
               ans.add(arr[j]);
                i=j;
            }
            
            
        }
        return ans;
    }
}
