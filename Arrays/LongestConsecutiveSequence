TC: O(n)
SC-O(n)

class Solution {
    public int longestConsecutive(int[] nums) {
        
    if(nums.length==0)return 0;
   int longest=0;
    HashSet<Integer>set=new HashSet<>();

    for(int i:nums){
        set.add(i);
    }
    for(int i:set){
        if(!set.contains(i-1))//prev number then we will know it is in the sequence and consecutive
        {
              int currNum=i;
              int count=1;

           while(set.contains(currNum+1)){
            currNum++;
            count++;
           }
           longest=Math.max(longest,count);
        } 
    }
    return longest;
    }
}
