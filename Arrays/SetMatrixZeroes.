//TC-O(m*n)
//SC-O(1)



class Solution {
    public void setZeroes(int[][] matrix) {
        
        int m=matrix.length;
        int n=matrix[0].length;

         boolean firstRow=false;
         boolean firstCol=false;

         //if first row contains a zero
         for(int j=0;j<n;j++){
            if(matrix[0][j]==0){
                firstRow=true;
                break;
            }
         }
         // if first col contains a zero
         for(int i=0;i<m;i++){
            if(matrix[i][0]==0){
                firstCol=true;
                break;
            }
         }
      //mark rows and col that need to be zero
      for(int i=1;i<m;i++){
        for(int j=1;j<n;j++){
              if(matrix[i][j]==0){//here [1,1]
                  matrix[i][0]=0;
                  matrix[0][j]=0;

              }
        }
      }
           //using markers to fill zero
            for(int i=1;i<m;i++){
        for(int j=1;j<n;j++){
        if(matrix[i][0]==0 || matrix[0][j]==0){
            matrix[i][j]=0;
        }
        }
            }
            //zero the first row 
            if(firstRow){
                for(int j=0;j<n;j++){
                    matrix[0][j]=0;
                }
            }
        //zero the first col
        if(firstCol){
            for(int i=0;i<m;i++){
                matrix[i][0]=0;
            }
        }

    }
}
