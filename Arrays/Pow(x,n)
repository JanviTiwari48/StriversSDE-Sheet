//Tc:O(n)
SC:O(1)
class Solution {
    public double myPow(double x, int n) {
        if(n==0)
        return 1;

        double ans=1.0;
        long N=n;

        if(N<0){
            x=1/x;
            N=-N;
        }
   while(N>0){
    if(N%2==1){//when n is odd 
        ans=ans*x;
    }
    x=x*x;
    N=N/2;
   }
return ans;
    }
}
