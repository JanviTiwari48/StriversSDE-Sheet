TC:O(n)
SC:O(n)
class Solution {
    public long subarrayXor(int arr[], int k) {
        // code here
        HashMap<Integer,Integer>map=new HashMap<>();
        
        int xor=0;int count=0;
        
        map.put(0,1);
        
        for(int n:arr){
            xor=xor^n;
            count=count+map.getOrDefault(xor^k,0);
            
            map.put(xor,map.getOrDefault(xor,0)+1);
        }
        return count;
    }
}
