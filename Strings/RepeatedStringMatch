TC:O(n+m)
SC:O(n+m)
class Solution {
    public int repeatedStringMatch(String a, String b) {
        
        StringBuilder sb=new StringBuilder();
        int count=0;

        while(sb.length()<b.length()){//(0<8)
            sb.append(a);//abcd
            count++;
            //abcdabcd (when 4<8)
        }

        if(sb.toString().contains(b))return count;
        

        //append one more time
        sb.append(a);//abcdabcdabcd
        count++;

        if(sb.toString().contains(b))return count;
       
        return -1;

    }
}
