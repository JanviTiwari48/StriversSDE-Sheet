class Solution {
    public int findPages(int[] arr, int k) {
        // code here
        int n=arr.length;
        if(k>n)return -1;
        
        long low=0;
        long high=0;
        
        for(int pages:arr){
            low=Math.max(low,pages);
            high=high+pages;
        }
        long ans=-1;
        
        while(low<=high){
            long mid=low+(high-low)/2;
            
            if(isPossible(arr,k,mid)){
                ans=mid;
                high=mid-1;
            }else low=mid+1;
        }
        return (int) ans;
    }
    private boolean isPossible(int[] arr ,int students, long maxPages){
        int count=1;
        long pages=0;
        
        for(int book:arr){
            if(pages+book<=maxPages) pages=pages+book;
            else {
                count++;
                pages=book;
                
                if(count>students)return false;
            }
            
        }
        return true;
    }
}
