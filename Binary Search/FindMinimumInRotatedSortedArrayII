class Solution {
    public int findMin(int[] nums) {
        
        int low=0;
        int high=nums.length-1;

        while(low<=high){
            int mid=low+(high-low)/2;
            if(nums[mid]<nums[high])high=mid;//ans lies at right
            else if(nums[mid]>nums[high])low=mid+1;//ans is in left of mid or mid itself
            else high--;//duplicate values
        }  
       return nums[low];
    }
}
