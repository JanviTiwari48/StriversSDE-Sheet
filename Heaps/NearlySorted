
class Solution {
    public void nearlySorted(int[] arr, int k) {
        // code here
        
        PriorityQueue<Integer>pq=new PriorityQueue<>();
        
        int idx=0;
        
        for(int n: arr){
            pq.add(n);
            
            if(pq.size()>k){
                arr[idx]=pq.remove();
                idx++;
            }
        }
        while(pq.size()>0){
            arr[idx]=pq.remove();
            idx++;
        }
    }
}
