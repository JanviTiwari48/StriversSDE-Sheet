

class maxHeap {

    private ArrayList<Integer> heap;

    // Constructor
    public maxHeap() {
        heap = new ArrayList<>();
    }

    // Insert x into the heap
    public void push(int x) {
        heap.add(x);

        int index = heap.size() - 1;

        while (index > 0) {
            int parent = (index - 1) / 2;

            if (heap.get(parent) >= heap.get(index))
                break;

            swap(parent, index);
            index = parent;
        }
    }

    // Remove the top (maximum) element
    public void pop() {
        if (heap.isEmpty())
            return;

        int last = heap.remove(heap.size() - 1);

        if (heap.isEmpty())
            return;

        heap.set(0, last);

        int index = 0;
        int n = heap.size();

        while (true) {
            int left = 2 * index + 1;
            int right = 2 * index + 2;
            int largest = index;

            if (left < n && heap.get(left) > heap.get(largest))
                largest = left;

            if (right < n && heap.get(right) > heap.get(largest))
                largest = right;

            if (largest == index)
                break;

            swap(index, largest);
            index = largest;
        }
    }

    // Return the top element or -1 if empty
    public int peek() {
        if (heap.isEmpty())
            return -1;

        return heap.get(0);
    }

    // Return the number of elements in the heap
    public int size() {
        return heap.size();
    }

    private void swap(int i, int j) {
        int temp = heap.get(i);
        heap.set(i, heap.get(j));
        heap.set(j, temp);
    }
}
