class Solution {
    public static int minCost(int[] arr) {
        // code here
        int cost=0;
        
        PriorityQueue<Integer>pq=new PriorityQueue<>();
        
        for(int n : arr){
            pq.add(n);
        }
        
        while(pq.size()>1){
            int x=pq.remove();
            int y=pq.remove();
            
            int sum=x+y;
            
              pq.add(sum);
            cost=cost+sum;
          
        }
        return cost;
    }
}
