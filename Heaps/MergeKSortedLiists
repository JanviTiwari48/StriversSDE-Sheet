
class Solution {
    public ListNode mergeKLists(ListNode[] lists) {
        
        PriorityQueue<ListNode>pq=new PriorityQueue<>((a,b)->a.val-b.val);

        for(ListNode head:lists){//add heads of each list
            if(head!=null)pq.add(head);

        }
     ListNode dummy=new ListNode(0);
     ListNode tail=dummy;

     while(pq.size()>0){
        ListNode curr=pq.remove();//the smallest of all the heads
        tail.next=curr;
        tail=tail.next;

        if(curr.next!=null)pq.add(curr.next);// curr head ka next
     }
return dummy.next;
    }
}
