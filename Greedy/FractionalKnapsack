class Solution {
    public double fractionalKnapsack(int[] val, int[] wt, int capacity) {

    int n=val.length;
    
    Integer[] index=new Integer[n];//wrapper class coz of sort function we need dynamic array
    
    for(int i=0;i<n;i++){
        index[i]=i;
    }
     // Sort indices based on value/weight ratio in descending order
     Arrays.sort(index,(a,b)->Double.compare((double)val[b]/wt[b],(double)val[a]/wt[a]));
     
     double ans=0.0;
     
     for(int i:index){
         if(wt[i]<=capacity){
             ans=ans+val[i];
             capacity=capacity-wt[i];
         }else{
             ans=ans+((double) val[i]/wt[i])*capacity;
             break;
         }
     }
     return ans;
    }
}
