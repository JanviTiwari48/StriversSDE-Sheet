
class Solution {
    public ListNode removeNthFromEnd(ListNode head, int n) {

       ListNode slow=head;
       ListNode fast=head;

       for(int i=1;i<=n;i++){
        fast=fast.next;//move fast n steps ahead
       }
       if(fast==null)return head.next;
       while(fast.next!=null){
        slow=slow.next;
        fast=fast.next;
       } 
       slow.next=slow.next.next;//change the pointer

       return head;
    }
}
