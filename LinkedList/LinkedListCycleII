
public class Solution {
    public ListNode detectCycle(ListNode head) {
        
        ListNode slow=head;
        ListNode fast=head;

        while(fast!=null && fast.next!=null){//detect cycle
            slow=slow.next;
            fast=fast.next.next;
            if(slow==fast)break;
        }

        if(fast==null || fast.next==null){
            return null;
        }
        ListNode temp=head;
        while(temp!=slow){
            temp=temp.next;
            slow=slow.next;
        }
        return slow;
    }
}
